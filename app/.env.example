# Front-end env. Copy to `.env` and fill to enable the real backend.
# Leave VITE_FUNCTIONS_URL empty to run in prototype mode (localStorage).

# Supabase Edge Functions base URL (e.g. https://<ref>.supabase.co/functions/v1)
VITE_FUNCTIONS_URL=

# Org API key (x-api-key) for the /v1-* resource functions (integrations connect/list).
VITE_ORG_API_KEY=

# (future) supabase-js for reads — when migrating screens off the local store
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
