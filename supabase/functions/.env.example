# Edge Function secrets — set with `supabase secrets set --env-file supabase/functions/.env`
# (SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically in deployed functions;
#  set them only for `supabase functions serve` locally.)

# Asaas (PSP)
ASAAS_API_KEY=your_asaas_api_key
ASAAS_ENV=sandbox                # sandbox | production
ASAAS_WEBHOOK_TOKEN=a_random_token_you_also_set_in_asaas_webhook_config

# CORS (the member-app origin)
CORS_ORIGIN=*

# Only needed for local `functions serve`:
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_SERVICE_ROLE_KEY=...
